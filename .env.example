# CORS origin for the Socket.IO server.
#
# Production: set to your exact deployed URL, e.g.:
#   CORS_ORIGIN=https://mygame.example.com
#
# Local dev (single server): leave unset — the frontend is served from the
# same Express server, so CORS does not apply (same-origin requests bypass it).
#
# Local dev (split origin, e.g. Vite on :5173 talking to backend on :3000):
#   CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=

# Trust the X-Forwarded-For header for real client IPs when behind a reverse proxy.
#
# Production (nginx, Caddy, Heroku, Railway, Render, etc.): set to true so the
# per-IP connection limit uses the real client IP instead of the proxy's IP
# (which would bucket ALL users together under one limit).
#
# Local dev / direct exposure: leave unset or false — trusting the header when
# there is no proxy allows clients to spoof any IP and bypass the connection limit.
TRUST_PROXY=

# Maximum simultaneous Socket.IO connections allowed from a single IP address.
# Connections beyond this limit are refused before any application state is allocated.
# Raise this if players commonly share a NAT (school, office).
CONNECTIONS_PER_IP=10

# Maximum number of players allowed in the matchmaking queue at once.
# Players who try to queue when it is full receive a queue-full event instead.
# Raise this for higher-traffic deployments.
MAX_QUEUE_SIZE=100
